{
  "default": {
    "require": [
      "features/step_definitions/**/*.js",
      "features/support/**/*.js"
    ],
    "format": [
      "progress-bar",
      "html:reports/cucumber-report.html",
      "json:reports/cucumber-report.json"
    ],
    "paths": [
      "features/**/*.feature"
    ],
    "publishQuiet": true,
    "retry": 1
  }
}
